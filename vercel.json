{
  "rewrites": [
    { "source": "/api/parse", "destination": "/api/parse.js" },
    { "source": "/api/download", "destination": "/api/download.js" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "functions": {
    "api/parse.js": {
      "maxDuration": 30
    }
  }
}
