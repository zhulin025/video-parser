{
  "functions": {
    "api/parse.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
       "source": "/(.*)",
       "destination": "/public/$1"
    }
  ]
}
